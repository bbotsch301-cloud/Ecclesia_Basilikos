# =============================================================================
# Environment Variables for Ecclesia Basilikos
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------- Required ----------

# PostgreSQL connection string (Neon serverless)
DATABASE_URL=postgresql://user:password@host/dbname

# Secret used to sign session cookies (use a long random string)
SESSION_SECRET=your-session-secret-here

# Base URL of the application (used for email links, redirects, etc.)
# Must be set in production. Example: https://yourdomain.com
BASE_URL=http://localhost:5000

# ---------- Email (Gmail SMTP) ----------

# Gmail address used to send transactional and bulk emails
GMAIL_EMAIL=you@gmail.com

# Gmail app password (generate at https://myaccount.google.com/apppasswords)
GMAIL_APP_PASSWORD=your-app-password

# ---------- AI Features ----------

# Anthropic API key (optional, enables AI-powered features)
# ANTHROPIC_API_KEY=sk-ant-...

# ---------- Server ----------

# Port the server listens on (default: 5000)
# PORT=5000

# Node environment: "development" or "production"
# NODE_ENV=development

# Logging level: trace, debug, info, warn, error, fatal (default: info)
# LOG_LEVEL=info

# ---------- Object / File Storage ----------

# Comma-separated public object search paths (optional)
# PUBLIC_OBJECT_SEARCH_PATHS=./public/objects

# Private object storage directory (optional)
# PRIVATE_OBJECT_DIR=./private/objects

# ---------- Square (Payments) ----------

# Square access token (enables self-service payments)
# SQUARE_ACCESS_TOKEN=EAAAl...

# Square location ID (from Square Dashboard > Locations)
# SQUARE_LOCATION_ID=L...

# Square webhook signature key (from Square Dashboard > Webhooks)
# SQUARE_WEBHOOK_SIGNATURE_KEY=...

# Square environment: "sandbox" or "production" (default: sandbox)
# SQUARE_ENVIRONMENT=sandbox

# Square subscription plan variation ID (for $50/mo installment plan, from Square Catalog)
# SQUARE_SUBSCRIPTION_PLAN_ID=...

# ---------- Stripe (Legacy — kept for in-flight payments) ----------

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---------- Proof Vault ----------

# Max upload file size in bytes (optional, default: 50 MB)
# PROOF_VAULT_MAX_FILE_SIZE=52428800
